{
  "name": "tamedtable",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun x cucumber-js --profile headless ; bun x cucumber-js --profile cli",
    "test:offline": "bun test && bun x cucumber-js --profile cli --tags @offline"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.2",
    "@tamedtable/cli": "workspace:*",
    "@tamedtable/core": "workspace:*",
    "@tamedtable/headless": "workspace:*",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
